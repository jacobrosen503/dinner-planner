# Copy to .env and fill in values

# Required for Instagram screenshot extraction
ANTHROPIC_API_KEY=sk-ant-...

# Optional — adds thousands more recipes
SPOONACULAR_API_KEY=

# Set automatically by Railway — no need to set these manually
PORT=3001
NODE_ENV=production

# Railway: set this to the path of your mounted volume (e.g. /data)
# This is where recipes-db.json gets stored so it survives redeploys
DATA_DIR=/data
